# Copy to .env for local development:  cp .env.example .env
#
# ⚠️  READ THIS — frontend env vars work differently from backend ones.
#
# Vite substitutes these into the JavaScript bundle AT BUILD TIME. They are
# not read at runtime, and they are fully visible to anyone who opens DevTools.
#
#   • Only ever put PUBLIC values here: API URLs, feature flags, publishable keys.
#   • NEVER put a database URL, JWT secret, or any private API key here.
#     It would be shipped to every visitor's browser.
#
# Because the value is baked in at build time, each environment needs its own
# build — you cannot build once and re-point it at a different API later.
#
# Only variables prefixed with VITE_ are exposed to your code. That prefix is
# a safety mechanism: it makes leaking a secret require a deliberate rename.

VITE_API_URL=http://localhost:3000
