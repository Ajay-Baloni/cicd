// Prisma 7 keeps the datasource URL in prisma.config.ts, not here.
// Create a migration with: npm run migrate:dev -- --name <description>

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String   @id @default(uuid())
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}
