# Copy to .env for local development:  cp .env.example .env
#
# This file is COMMITTED and documents every variable the backend needs.
# The real .env is gitignored and never leaves your machine.
#
# In production these are NOT read from a file — ECS/EC2 injects them from
# AWS SSM Parameter Store, so the same image runs in every environment.

NODE_ENV=development
PORT=3000

# When running the API on your host against compose Postgres, use localhost.
# Inside the compose network the host is the service name: postgres.
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# Comma-separated list of browser origins allowed to call this API.
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=debug

# Grace period for in-flight requests to finish on SIGTERM.
SHUTDOWN_TIMEOUT_MS=10000
